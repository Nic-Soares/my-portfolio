{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "vite",
    "build": "deno check client/src/app/main.tsx && vite build",
    "preview": "vite preview",
    "typecheck": "deno check client/src/app/main.tsx",
    "lint": "deno run -A npm:@biomejs/biome@2 lint .",
    "format": "deno run -A npm:@biomejs/biome@2 format --write .",
    "check": "deno run -A npm:@biomejs/biome@2 check --write ."
  },
  "imports": {
    "react": "npm:react@^19.2.3",
    "react/": "npm:/react@^19.2.3/",
    "react-dom": "npm:react-dom@^19.2.3",
    "react-dom/client": "npm:react-dom@^19.2.3/client",
    "react-router-dom": "npm:react-router-dom@^7.12.0",
    "clsx": "npm:clsx@^2.1.1",
    "@types/react": "npm:@types/react@^19.2.8",
    "@types/react-dom": "npm:@types/react-dom@^19.2.3",
    "@material/web/": "npm:/@material/web@^2.4.1/",
    "vite": "npm:vite@^7.3.1",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^5.1.2",
    "vite-plugin-svgr": "npm:vite-plugin-svgr@^4.5.0",
    "@/": "./client/src/",
    "@assets/": "./client/src/assets/"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "fmt": {
    "exclude": ["dist", "node_modules"]
  },
  "lint": {
    "exclude": ["dist", "node_modules"]
  }
}
